{% extends 'base.html.twig' %}

{% block title %}{{ event.title }} | EventReserva{% endblock %}

{% block body %}
<div class="animate-up">
    <div style="margin-bottom: 2rem;">
        <a href="{{ path('event_list') }}" style="color: var(--amber); text-decoration: none; font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; display: flex; align-items: center; gap: 0.5rem;">
            ← Back to Events
        </a>
    </div>

    <div class="card" style="display: grid; grid-template-columns: 1fr 1fr; min-height: 500px;">
        <div style="position: relative; overflow: hidden;">
            {% if event.image %}
                <img src="{{ event.image starts with 'http' ? event.image : asset('uploads/events/' ~ event.image) }}" alt="{{ event.title }}" style="width: 100%; height: 100%; object-fit: cover;">
            {% else %}

                <div style="width: 100%; height: 100%; background: var(--surface-2); display: flex; align-items: center; justify-content: center; font-size: 5rem;">
                    🗓
                </div>
            {% endif %}
        </div>

        <div style="padding: 3rem; display: flex; flex-direction: column;">
            <div style="margin-bottom: 2rem;">
                <p class="er-eyebrow">⬡ Event Details</p>
                <h1 class="er-title">{{ event.title }}</h1>
                <div style="display: flex; gap: 1.5rem; margin-top: 1rem; font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-secondary);">
                    <span>📅 {{ event.date|date('F d, Y • H:i') }}</span>
                    <span>📍 {{ event.location }}</span>
                    <span style="color: var(--amber);">🎟 {{ event.seats }} Remaining</span>
                </div>
            </div>

            <div style="flex: 1; border-top: 1px solid var(--border); padding-top: 2rem;">
                <p style="color: var(--text-secondary); line-height: 1.8; font-size: 1.1rem;">{{ event.description|nl2br }}</p>
            </div>

            <div style="margin-top: 3rem; display: flex; justify-content: space-between; align-items: center; background: var(--surface-2); padding: 1.5rem; border-radius: var(--radius-md);">
                <div>
                    {% if event.seats > 0 %}
                        <a href="{{ path('reservation_new', {'id': event.id}) }}" class="btn btn-primary" style="padding: 1rem 2.5rem; font-size: 1rem;">Reserve your seat</a>
                    {% else %}
                        <button class="btn btn-outline" disabled style="opacity: 0.5;">Event Fully Booked</button>
                    {% endif %}
                </div>

                {% if is_granted('ROLE_ADMIN') %}
                    <div style="display: flex; gap: 0.75rem;">
                        <a href="{{ path('admin_event_reservations', {'id': event.id}) }}" class="btn btn-outline" style="padding: 0.5rem 1rem; border-color: var(--amber); color: var(--amber);">Reservations</a>
                        <a href="{{ path('admin_event_edit', {'id': event.id}) }}" class="btn btn-outline" style="padding: 0.5rem 1rem;">Edit</a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
