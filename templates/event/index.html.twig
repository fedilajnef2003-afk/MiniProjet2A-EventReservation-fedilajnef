{% extends 'base.html.twig' %}

{% block title %}Explore Events | EventReserva{% endblock %}

{% block body %}
    <div class="animate-up">
        <div style="margin-bottom: 3rem;">
            <p class="er-eyebrow">⬡ Discover the Best</p>
            <h1 class="er-title">Featured <em>Events</em></h1>
            <p style="color: var(--text-secondary); max-width: 600px;">Explore premium events, from tech conferences to exclusive workshops. Book your seat in seconds.</p>
        </div>

        <div class="event-list">
            {% for event in events %}
                <article class="event-card">
                    <div class="event-image-container">
                        {% if event.image %}
                            <img src="{{ event.image starts with 'http' ? event.image : asset('uploads/events/' ~ event.image) }}" alt="{{ event.title }}" style="width: 100%; height: 100%; object-fit: cover;">
                        {% else %}

                            <div style="width: 100%; height: 100%; background: var(--surface-2); display: flex; align-items: center; justify-content: center; color: var(--text-muted); font-size: 3rem;">
                                🗓
                            </div>
                        {% endif %}
                        <div class="event-badge">{{ event.seats }} seats left</div>
                    </div>
                    
                    <div style="padding: 1.5rem;">
                        <h2 style="font-family: var(--font-display); font-size: 1.25rem; margin-bottom: 0.75rem; color: var(--text-primary);">{{ event.title }}</h2>
                        <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem; font-size: 0.875rem; color: var(--text-secondary);">
                            <span style="display: flex; align-items: center; gap: 0.5rem;">📅 {{ event.date|date('M d, Y • H:i') }}</span>
                            <span style="display: flex; align-items: center; gap: 0.5rem;">📍 {{ event.location }}</span>
                        </div>
                        
                        <div style="display: flex; gap: 0.75rem;">
                            <a href="{{ path('event_show', {'id': event.id}) }}" class="btn btn-primary" style="flex: 1;">View Details</a>
                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('admin_event_edit', {'id': event.id}) }}" class="btn btn-outline" style="padding: 0.5rem 0.75rem;">⚙️</a>
                            {% endif %}
                        </div>
                    </div>
                </article>
            {% else %}
                <div style="grid-column: 1/-1; text-align: center; padding: 6rem 2rem; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg);">
                    <div style="font-size: 3rem; margin-bottom: 1rem;">🔍</div>
                    <h3 style="font-family: var(--font-display); font-size: 1.5rem; margin-bottom: 0.5rem;">No events found</h3>
                    <p style="color: var(--text-muted);">Check back later or search for something else.</p>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
