{% extends 'base.html.twig' %}

{% block title %}Manage Event | EventReserva{% endblock %}

{% block body %}
<div class="animate-up" style="max-width: 800px; margin: 0 auto;">
    <div style="margin-bottom: 2rem;">
        <a href="{{ path('admin_dashboard') }}" style="color: var(--amber); text-decoration: none; font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; display: flex; align-items: center; gap: 0.5rem;">
            ← Back to Dashboard
        </a>
    </div>

    <div class="card" style="padding: 3rem;">
        <p class="er-eyebrow">⬡ Platform Management</p>
        <h1 class="er-title">{{ event.id ? 'Edit' : 'Create' }} <em>Event</em></h1>
        
        {{ form_start(form, {'attr': {'style': 'margin-top: 2.5rem;'}}) }}
            {{ form_errors(form) }}

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
                <div class="form-group">
                    {{ form_label(form.title, 'Event Title', {'label_attr': {'class': 'er-stat-label', 'style': 'display: block; margin-bottom: 0.5rem; color: var(--text-muted);'}}) }}
                    {{ form_widget(form.title, {'attr': {'class': 'form-input', 'placeholder': 'e.g. AI Summit 2026'}}) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.location, 'Location', {'label_attr': {'class': 'er-stat-label', 'style': 'display: block; margin-bottom: 0.5rem; color: var(--text-muted);'}}) }}
                    {{ form_widget(form.location, {'attr': {'class': 'form-input', 'placeholder': 'e.g. Paris, France'}}) }}
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
                <div class="form-group">
                    {{ form_label(form.date, 'Event Date & Time', {'label_attr': {'class': 'er-stat-label', 'style': 'display: block; margin-bottom: 0.5rem; color: var(--text-muted);'}}) }}
                    {{ form_widget(form.date, {'attr': {'class': 'form-input'}}) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.seats, 'Capacity (Seats)', {'label_attr': {'class': 'er-stat-label', 'style': 'display: block; margin-bottom: 0.5rem; color: var(--text-muted);'}}) }}
                    {{ form_widget(form.seats, {'attr': {'class': 'form-input'}}) }}
                </div>
            </div>

            <div style="margin-bottom: 1.5rem;">
                {{ form_label(form.image, 'Image URL', {'label_attr': {'class': 'er-stat-label', 'style': 'display: block; margin-bottom: 0.5rem; color: var(--text-muted);'}}) }}
                {{ form_widget(form.image, {'attr': {'class': 'form-input', 'placeholder': 'https://...'}}) }}
            </div>

            <div style="margin-bottom: 2rem;">
                {{ form_label(form.description, 'Description', {'label_attr': {'class': 'er-stat-label', 'style': 'display: block; margin-bottom: 0.5rem; color: var(--text-muted);'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-input', 'style': 'height: 150px; resize: vertical;'}}) }}
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 3rem;">
                <button type="submit" class="btn btn-primary" style="flex: 1; padding: 1rem;">{{ event.id ? 'Save Changes' : 'Publish Event' }}</button>
                <a href="{{ path('admin_dashboard') }}" class="btn btn-outline" style="flex: 1; padding: 1rem;">Cancel</a>
            </div>
        {{ form_end(form) }}

        {% if event.id %}
            <div style="margin-top: 1.5rem; border-top: 1px solid var(--border); padding-top: 1.5rem; display: flex; justify-content: flex-end;">
                <form method="post" action="{{ path('admin_event_delete', {'id': event.id}) }}" onsubmit="return confirm('Are you sure you want to delete this event? This action cannot be undone.');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
                    <button class="btn" style="background: #ff4444; color: white; border: none; padding: 0.75rem 1.5rem; cursor: pointer; border-radius: 4px; font-weight: 600;">Delete Event</button>
                </form>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
