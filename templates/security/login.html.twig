{% extends 'base.html.twig' %}

{% block title %}Log in | EventReserva{% endblock %}

{% block body %}
<div class="form-container">
    <div style="text-align: center; margin-bottom: 2rem;">
        <h1 class="form-title">Welcome Back</h1>
        <p style="color: var(--zinc-500);">Sign in to your account to manage your reservations.</p>
    </div>

    <form method="post">
        {% if error %}
            <div class="alert alert-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <div class="form-group">
            <label for="inputUsername" class="form-label">Username</label>
            <input type="text" value="{{ last_username }}" name="_username" id="inputUsername" class="form-input" autocomplete="username" required autofocus placeholder="Enter your username">
        </div>

        <div class="form-group">
            <label for="inputPassword" class="form-label">Password</label>
            <input type="password" name="_password" id="inputPassword" class="form-input" autocomplete="current-password" required placeholder="••••••••">
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button class="btn btn-primary btn-block mt-3" type="submit" style="padding: 0.8rem;">
            Sign In
        </button>
        
        <div style="margin-top: 1.5rem; text-align: center; font-size: 0.875rem; color: var(--zinc-500);">
            Don't have an account? <a href="{{ path('app_register') }}" style="color: var(--brand-primary); font-weight: 700;">Create one</a>
        </div>
    </form>
</div>
{% endblock %}
