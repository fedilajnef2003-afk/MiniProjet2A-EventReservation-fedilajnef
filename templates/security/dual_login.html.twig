{% extends 'base.html.twig' %}

{% block title %}Login | EventReserva{% endblock %}

{% block body %}
<div class="auth-wrapper {% if is_admin_login %}admin-active{% endif %} animate-up" id="auth-wrapper" style="border: 1px solid var(--border); box-shadow: var(--shadow-card), var(--shadow-glow);">
    
    <!-- CLIENT LOGIN FORM -->
    <div class="auth-side client-side" style="background: var(--surface);">
        <p class="er-eyebrow">⬡ Welcome Back</p>
        <h1 class="er-title">Client <em>Login</em></h1>
        <form method="post" action="{{ path('app_login') }}" style="margin-top: 2rem;">
            {% if error and not is_admin_login %}
                <div class="alert alert-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            <div style="margin-bottom: 1.5rem;">
                <label class="er-stat-label" style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Username</label>
                <input type="text" value="{{ not is_admin_login ? last_username : '' }}" name="_username" class="form-input" autocomplete="username" required autofocus>
            </div>
            <div style="margin-bottom: 2rem;">
                <label class="er-stat-label" style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Password</label>
                <input type="password" name="_password" class="form-input" autocomplete="current-password" required>
            </div>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <button class="btn btn-primary" style="width: 100%; padding: 1rem;" type="submit">Sign In to Account</button>
        </form>
        <p class="mt-3 text-center" style="font-size: 0.875rem; color: var(--text-secondary); margin-top: 1.5rem;">New here? <a href="{{ path('app_register') }}" style="color: var(--amber); text-decoration: none; font-weight: 700;">Create account</a></p>
    </div>

    <!-- ADMIN LOGIN FORM -->
    <div class="auth-side admin-side" style="background: var(--surface);">
        <p class="er-eyebrow">⬡ Secure Access</p>
        <h1 class="er-title">Admin <em>Portal</em></h1>
        <form method="post" action="{{ path('admin_login') }}" style="margin-top: 2rem;">

            {% if error and is_admin_login %}
                <div class="alert alert-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            <div style="margin-bottom: 1.5rem;">
                <label class="er-stat-label" style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Admin ID</label>
                <input type="text" value="{{ is_admin_login ? last_username : '' }}" name="_username" class="form-input" autocomplete="username" required>
            </div>
            <div style="margin-bottom: 2rem;">
                <label class="er-stat-label" style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">Security Password</label>
                <input type="password" name="_password" class="form-input" autocomplete="current-password" required>
            </div>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <button class="btn btn-primary" style="width: 100%; padding: 1rem; background: var(--amber);" type="submit">Unlock Portal</button>
        </form>
         <p class="mt-3 text-center" style="font-size: 0.875rem; color: var(--text-secondary); margin-top: 1.5rem;">Need access? <a href="{{ path('admin_register') }}" style="color: var(--amber); text-decoration: none; font-weight: 700;">Register Admin</a></p>
    </div>

    <!-- SLIDING OVERLAY -->
    <div class="auth-overlay-container">
        <div class="auth-overlay" style="background: linear-gradient(135deg, var(--bg) 0%, var(--surface-2) 100%); border-left: 1px solid var(--border); border-right: 1px solid var(--border);">
            <div class="overlay-panel overlay-left">
                <h2 style="font-family: var(--font-display); font-size: 2rem; margin-bottom: 1rem;">Client Access</h2>
                <p style="color: var(--text-secondary); margin-bottom: 2.5rem;">Returning to standard event exploration? Switch back to the client login.</p>
                <button class="btn btn-outline" id="to-client">← Client Portal</button>
            </div>
            <div class="overlay-panel overlay-right">
                <h2 style="font-family: var(--font-display); font-size: 2rem; margin-bottom: 1rem;">Platform Admin</h2>
                <p style="color: var(--text-secondary); margin-bottom: 2.5rem;">Access the administrator dashboard to manage events and reservations.</p>
                <button class="btn btn-outline" id="to-admin">Admin Portal →</button>
            </div>
        </div>
    </div>
</div>

<script>
    const wrapper = document.getElementById('auth-wrapper');
    const toAdmin = document.getElementById('to-admin');
    const toClient = document.getElementById('to-client');

    toAdmin.addEventListener('click', () => {
        wrapper.classList.add('admin-active');
    });

    toClient.addEventListener('click', () => {
        wrapper.classList.remove('admin-active');
    });
</script>
{% endblock %}
