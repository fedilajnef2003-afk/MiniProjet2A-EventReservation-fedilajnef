{% extends 'base.html.twig' %}

{% block title %}Sign Up | EventReserva{% endblock %}

{% block body %}
<div class="auth-wrapper {% if is_admin_register %}admin-active{% endif %} animate-up" id="auth-wrapper" style="border: 1px solid var(--border); box-shadow: var(--shadow-card);">
    
    <!-- CLIENT REGISTER FORM -->
    <div class="auth-side client-side" style="background: var(--surface);">
        <p class="er-eyebrow">⬡ Join Us</p>
        <h1 class="er-title">Client <em>SignUp</em></h1>
        {{ form_start(clientForm, {'attr': {'style': 'margin-top: 1.5rem;'}}) }}
            <div style="margin-bottom: 1rem;">
                {{ form_label(clientForm.username, 'Username', {'label_attr': {'class': 'er-stat-label', 'style': 'display: block; margin-bottom: 0.5rem; color: var(--text-muted);'}}) }}
                {{ form_widget(clientForm.username, {'attr': {'class': 'form-input', 'placeholder': 'Unique username'}}) }}
            </div>
            <div style="margin-bottom: 1rem;">
                {{ form_label(clientForm.plainPassword.first, 'Set Password', {'label_attr': {'class': 'er-stat-label', 'style': 'display: block; margin-bottom: 0.5rem; color: var(--text-muted);'}}) }}
                {{ form_widget(clientForm.plainPassword.first, {'attr': {'class': 'form-input', 'placeholder': 'Min. 8 characters'}}) }}
            </div>
            <div style="margin-bottom: 1.5rem;">
                {{ form_label(clientForm.plainPassword.second, 'Confirm Password', {'label_attr': {'class': 'er-stat-label', 'style': 'display: block; margin-bottom: 0.5rem; color: var(--text-muted);'}}) }}
                {{ form_widget(clientForm.plainPassword.second, {'attr': {'class': 'form-input'}}) }}
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem;">Create Account</button>
        {{ form_end(clientForm) }}
        <p class="mt-3 text-center" style="font-size: 0.875rem; color: var(--text-secondary); margin-top: 1.5rem;">Already have an account? <a href="{{ path('app_login') }}" style="color: var(--amber); text-decoration: none; font-weight: 700;">Log in</a></p>
    </div>

    <!-- ADMIN REGISTER FORM -->
    <div class="auth-side admin-side" style="background: var(--surface);">
        <p class="er-eyebrow">⬡ Administrative</p>
        <h1 class="er-title">Admin <em>Sign Up</em></h1>
        {{ form_start(adminForm, {'attr': {'style': 'margin-top: 1.5rem;'}}) }}
            <div style="margin-bottom: 1rem;">
                {{ form_label(adminForm.username, 'Admin Handle', {'label_attr': {'class': 'er-stat-label', 'style': 'display: block; margin-bottom: 0.5rem; color: var(--text-muted);'}}) }}
                {{ form_widget(adminForm.username, {'attr': {'class': 'form-input', 'placeholder': 'System username'}}) }}
            </div>
            <div style="margin-bottom: 1rem;">
                {{ form_label(adminForm.plainPassword.first, 'Security Password', {'label_attr': {'class': 'er-stat-label', 'style': 'display: block; margin-bottom: 0.5rem; color: var(--text-muted);'}}) }}
                {{ form_widget(adminForm.plainPassword.first, {'attr': {'class': 'form-input'}}) }}
            </div>
            <div style="margin-bottom: 1.5rem;">
                {{ form_label(adminForm.plainPassword.second, 'Verify Password', {'label_attr': {'class': 'er-stat-label', 'style': 'display: block; margin-bottom: 0.5rem; color: var(--text-muted);'}}) }}
                {{ form_widget(adminForm.plainPassword.second, {'attr': {'class': 'form-input'}}) }}
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem; background: var(--amber);">Initiate Admin</button>
        {{ form_end(adminForm) }}
         <p class="mt-3 text-center" style="font-size: 0.875rem; color: var(--text-secondary); margin-top: 1.5rem;">Already have an account? <a href="{{ path('app_login') }}" style="color: var(--amber); text-decoration: none; font-weight: 700;">Portal Login</a></p>
    </div>

    <!-- SLIDING OVERLAY -->
    <div class="auth-overlay-container">
        <div class="auth-overlay" style="background: linear-gradient(135deg, var(--bg) 0%, var(--surface-2) 100%);">
            <div class="overlay-panel overlay-left">
                <h2 style="font-family: var(--font-display); font-size: 2rem; margin-bottom: 1rem;">standard User</h2>
                <p style="color: var(--text-secondary); margin-bottom: 2.5rem;">Switch back to standard registration to start browsing events.</p>
                <button class="btn btn-outline" id="to-client">← Client SignUp</button>
            </div>
            <div class="overlay-panel overlay-right">
                <h2 style="font-family: var(--font-display); font-size: 2rem; margin-bottom: 1rem;">Administrator</h2>
                <p style="color: var(--text-secondary); margin-bottom: 2.5rem;">Switch to administrator registration to manage platform resources.</p>
                <button class="btn btn-outline" id="to-admin">Admin SignUp →</button>
            </div>
        </div>
    </div>
</div>

<script>
    const wrapper = document.getElementById('auth-wrapper');
    const toAdmin = document.getElementById('to-admin');
    const toClient = document.getElementById('to-client');

    toAdmin.addEventListener('click', () => {
        wrapper.classList.add('admin-active');
    });

    toClient.addEventListener('click', () => {
        wrapper.classList.remove('admin-active');
    });
</script>
{% endblock %}
