{% extends 'base.html.twig' %}

{% block title %}Join EventReserva{% endblock %}

{% block body %}
    <div class="form-container">
        <div style="text-align: center; margin-bottom: 2rem;">
            <h1 class="form-title">Create Account</h1>
            <p style="color: var(--zinc-500);">Join our community and start discovering amazing events.</p>
        </div>

        {{ form_start(registrationForm) }}
            <div class="form-group">
                {{ form_label(registrationForm.username, 'Username', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(registrationForm.username, {'attr': {'class': 'form-input', 'placeholder': 'Pick a unique username'}}) }}
            </div>

            <div class="form-group">
                {{ form_label(registrationForm.plainPassword.first, 'Password', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'form-input', 'placeholder': 'Min. 8 characters'}}) }}
            </div>

            <div class="form-group">
                {{ form_label(registrationForm.plainPassword.second, 'Confirm Password', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'form-input', 'placeholder': 'Repeat your password'}}) }}
            </div>

            <button type="submit" class="btn btn-primary mt-3 btn-block" style="padding: 0.8rem;">Create Account</button>
        {{ form_end(registrationForm) }}
        
        <div style="margin-top: 1.5rem; text-align: center; font-size: 0.875rem; color: var(--zinc-500);">
            Already have an account? <a href="{{ path('app_login') }}" style="color: var(--brand-primary); font-weight: 700;">Log in</a>
        </div>
    </div>
{% endblock %}
